{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/anthropic.js": { "maxDuration": 30,  "memory": 256 },
    "api/whisper.js":   { "maxDuration": 60,  "memory": 1024 },
    "api/stripe.js":    { "maxDuration": 15,  "memory": 256 },
    "api/auth.js":      { "maxDuration": 10,  "memory": 256 },
    "api/videos.js":    { "maxDuration": 10,  "memory": 256 }
  }
}
