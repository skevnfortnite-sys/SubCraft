{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/videos?action=cleanup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/admin?action=trigger-j3",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin?action=reset-credits",
      "schedule": "0 0 1 * *"
    }
  ]
}
